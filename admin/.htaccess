# Basic Authentication for the whole admin area.
# IMPORTANT: update AuthUserFile on production to the real absolute server path.
AuthType Basic
AuthName "HIGH Q Admin Access"
AuthUserFile "C:/xampp/htdocs/HIGH-Q/admin/.htpasswd"
Require valid-user

# Allow the password-recovery utility and error pages to bypass the outer prompt.
<FilesMatch "^(reset_htpasswd|rstpaswrd|create_htpasswd|create_pass|400|401|403|404|500|503)\.php$">
    AuthType None
    Require all granted
    Satisfy Any
    Order allow,deny
    Allow from all
</FilesMatch>

# Error Documents
ErrorDocument 400 /errors/400.php
ErrorDocument 401 /errors/401.php
ErrorDocument 403 /errors/403.php
ErrorDocument 404 /errors/404.php
ErrorDocument 500 /errors/500.php
ErrorDocument 503 /errors/503.php

# Prevent directory listing
Options -Indexes

# Enable URL rewriting
RewriteEngine On

# PHP Settings (only valid when using mod_php; comment out if using CGI/FPM)
<IfModule mod_php.c>
    php_value display_errors Off
    php_flag session.cookie_httponly on
</IfModule>
