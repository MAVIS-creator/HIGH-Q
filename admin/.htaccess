# Basic Authentication (temporarily disabled for local debugging)
# AuthType Basic
# AuthName "Admin Login"
# AuthUserFile "C:/xampp/htdocs/HIGH-Q/admin/.htpasswd"
# Require valid-user

# Allow accessing assets after authentication
<FilesMatch "\.(css|js|gif|jpg|jpeg|png|ico|woff|woff2|ttf|svg)$">
    Satisfy Any
    Allow from all
</FilesMatch>

# Error Documents
ErrorDocument 400 /errors/400.php
ErrorDocument 401 /errors/401.php
ErrorDocument 403 /errors/403.php
ErrorDocument 404 /errors/404.php
ErrorDocument 500 /errors/500.php
ErrorDocument 503 /errors/503.php

# Prevent directory listing
Options -Indexes

# Enable URL rewriting
RewriteEngine On

# Allow access to error pages
<FilesMatch "^(400|401|403|404|500)\.php$">
    Satisfy Any
    Require all granted
    Order allow,deny
    Allow from all
</FilesMatch>

# PHP Settings (only valid when using mod_php; comment out if using CGI/FPM)
<IfModule mod_php.c>
    php_value display_errors Off
    php_flag session.cookie_httponly on
</IfModule>
